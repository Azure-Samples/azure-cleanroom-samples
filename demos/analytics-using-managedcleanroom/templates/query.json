      {
        "executionSequence": 2,
        "data": "SELECT woodgrove_data.user_id FROM modified_northwind INNER JOIN woodgrove_data ON modified_northwind.hashed_email = woodgrove_data.hashed_email",
        "preConditions": [
          { "viewName": "modified_northwind", "minRowCount": 1000 },
          { "viewName": "woodgrove_data", "minRowCount": 1000 }
        ],
        "postFilters": []
      }
    ]
  },
