  "queryData": {
    "segments": [
      {
        "executionSequence": 1,
        "data": "CREATE OR REPLACE TEMP VIEW modified_northwind AS SELECT * FROM northwind_data WHERE annual_income > 100000 AND region IN ('IN', 'US', 'UK')",
